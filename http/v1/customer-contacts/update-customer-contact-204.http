### Setup for PUT 204
POST {{host}}/api/v1/customer-contacts
Content-Type: application/vnd.api+json
Accept: application/vnd.api+json

{
  "customerId": 701,
  "contactName": "Before Update",
  "phone": "+34 600000701",
  "email": "before.update@example.com"
}

> {%
client.test("setup status is 201 or 409", function() {
  client.assert(response.status === 201 || response.status === 409, "Expected 201 or 409");
});
%}

### PUT customer contact 204
PUT {{host}}/api/v1/customer-contacts/701
Content-Type: application/vnd.api+json
Accept: application/vnd.api+json

{
  "contactName": "After Update",
  "phone": "+34 600000702",
  "email": "after.update@example.com"
}

> {%
client.test("PUT returns 204", function() {
  client.assert(response.status === 204, "Expected 204");
});
%}
